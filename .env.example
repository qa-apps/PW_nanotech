# =============================================================================
# Nanotech.icu Test Environment Configuration
# =============================================================================
# Two tiers of credentials are used:
#   - NANOTECH_*     → Primary / "real" nanotech accounts (owner, demos, etc.)
#   - NANOTECH_TEST_* → Dedicated safe test accounts for automation
# =============================================================================

# --- Primary Nanotech accounts (real / production-like) ------------------------
NANOTECH_EMAIL=your_nanotech_email@example.com
NANOTECH_PASSPORT=your_nanotech_passport_number

# --- Dedicated test accounts (safe for Playwright / CI) ------------------------
NANOTECH_TEST_EMAIL=test_email_001007@proton.me
NANOTECH_TEST_PASSWORD=your_test_password
NANOTECH_TEST_PASSPORT=your_test_passport_number
